    <node id="Princess Augusta of Waldeck-Pyrmont">
      <data key="d0">Princess Augusta of Waldeck-Pyrmont</data>
      <data key="d1">person</data>
      <data key="d2">Princess Augusta of Waldeck-Pyrmont was a German noblewoman born on 21 July 1824 and died on 4 September 1893. She was the eldest daughter of George II, Prince of Waldeck and Pyrmont, and Princess Emma of Anhalt-Bernburg-Schaumburg-Hoym. She was an aunt of the Dutch queen regent Emma of Waldeck and Pyrmont and married Count Alfred of Stolberg-Stolberg on 15 June 1848, with whom she had seven children.</data>
      <data key="d3">chunk-4b4b32da40de7c315d4fc5bc3606929d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782054613</data>
      <data key="d6" />
    </node>
    <node id="George II, Prince of Waldeck and Pyrmont">
      <data key="d0">George II, Prince of Waldeck and Pyrmont</data>
      <data key="d1">person</data>
      <data key="d2">George II, Prince of Waldeck and Pyrmont was a German nobleman who ruled as Prince of Waldeck and Pyrmont from 1813 to 1845. He was born on 20 September 1789 and died on 15 May 1845. He was the son of George I, Prince of Waldeck and Pyrmont and Countess Princess Augusta of Schwarzburg-Sondershausen.</data>
      <data key="d3">chunk-4b4b32da40de7c315d4fc5bc3606929d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782054613</data>
      <data key="d6" />
    </node>
    <node id="Princess Emma of Anhalt-Bernburg-Schaumburg-Hoym">
      <data key="d0">Princess Emma of Anhalt-Bernburg-Schaumburg-Hoym</data>
      <data key="d1">person</data>
      <data key="d2">Princess Emma of Anhalt-Bernburg-Schaumburg-Hoym was the wife of George II, Prince of Waldeck and Pyrmont and the mother of Princess Augusta of Waldeck-Pyrmont.</data>
      <data key="d3">chunk-4b4b32da40de7c315d4fc5bc3606929d</data>
