      <data key="d1">organization</data>
      <data key="d2">The Ming dynasty was a Chinese dynasty that ruled from 1368 to 1644, known for its cultural achievements and military campaigns.</data>
      <data key="d3">chunk-f58fec195d8efa9069d2477d8a930f4c</data>
      <data key="d4">unknown_source</data>
