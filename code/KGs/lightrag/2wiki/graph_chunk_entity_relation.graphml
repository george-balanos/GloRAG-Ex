      <data key="d6" />
    </node>
    <node id="John Beach">
      <data key="d0">John Beach</data>
      <data key="d1">person</data>
      <data key="d2">Major John Beach was a United States Army officer who served during the Black Hawk and American Civil War. He was the last U.S. Indian Agent to the Sac and Fox tribes and hosted a council that led to the signing of a treaty for the purchase of much of Iowa from the Sac and Fox Indians in 1842.</data>
      <data key="d3">chunk-d1bb5cd9ff264b572149867bd71c495b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782054656</data>
      <data key="d6" />
    </node>
    <node id="Sac and Fox Tribes">
      <data key="d0">Sac and Fox Tribes</data>
      <data key="d1">organization</data>
      <data key="d2">The Sac and Fox Tribes are Native American tribes with whom John Beach served as an Indian Agent and with whom he negotiated a treaty for the purchase of land in Iowa.</data>
      <data key="d3">chunk-d1bb5cd9ff264b572149867bd71c495b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782054656</data>
      <data key="d6" />
    </node>
    <node id="General Joseph Street">
      <data key="d0">General Joseph Street</data>
      <data key="d1">person</data>
      <data key="d2">General Joseph Street was a predecessor of John Beach as the Indian Agent to the Sac and Fox tribes and was Beach's son-in-law.</data>
      <data key="d3">chunk-d1bb5cd9ff264b572149867bd71c495b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782054656</data>
      <data key="d6" />
    </node>
    <node id="Treaty for the Purchase of Iowa">
      <data key="d0">Treaty for the Purchase of Iowa</data>
      <data key="d1">event</data>
      <data key="d2">The Treaty for the Purchase of Iowa was signed in October 1842, resulting from a council hosted by John Beach, involving the Sac and Fox Indians.</data>
      <data key="d3">chunk-d1bb5cd9ff264b572149867bd71c495b</data>
