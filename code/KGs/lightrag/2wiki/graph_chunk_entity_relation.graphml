      <data key="d0">Herman of Ename</data>
      <data key="d1">person</data>
      <data key="d2">Herman of Ename was the Count of Verdun who retired to a monastery in 1024, allowing Louis I to assume the position.</data>
      <data key="d3">chunk-758a0a6b7851ac012d0c9fd434d94410</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782055853</data>
