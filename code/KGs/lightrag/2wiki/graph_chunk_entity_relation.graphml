    <node id="Germanicus">
      <data key="d0">Germanicus</data>
      <data key="d1">person</data>
      <data key="d2">Germanicus was a popular Roman general and the father of Caligula. He died at Antioch in 19 AD.</data>
      <data key="d3">chunk-8d2b3198b39b98b16e57ae034086b62f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782055011</data>
