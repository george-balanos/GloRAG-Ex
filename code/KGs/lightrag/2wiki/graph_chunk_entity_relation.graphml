    <node id="Seleucus VI">
      <data key="d0">Seleucus VI</data>
      <data key="d1">person</data>
      <data key="d2">Seleucus VI was the son of Antiochus VIII and a rival of Antiochus IX, who killed Antiochus IX in 95 BC.</data>
