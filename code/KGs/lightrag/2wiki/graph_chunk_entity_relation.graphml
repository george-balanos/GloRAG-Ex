    </node>
    <node id="Emma of Waldeck and Pyrmont">
      <data key="d0">Emma of Waldeck and Pyrmont</data>
      <data key="d1">person</data>
      <data key="d2">Emma of Waldeck and Pyrmont was the Dutch queen regent and the niece of Princess Augusta of Waldeck-Pyrmont.</data>
      <data key="d3">chunk-4b4b32da40de7c315d4fc5bc3606929d</data>
