      <data key="d0">Armagnac–Burgundian Civil War</data>
      <data key="d1">event</data>
      <data key="d2">The Armagnac–Burgundian Civil War was a conflict in France triggered by John the Fearless's political actions.</data>
      <data key="d3">chunk-339288817d6c7dccf7a63a29fcd9b0ff</data>
      <data key="d4">unknown_source</data>
