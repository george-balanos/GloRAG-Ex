    </edge>
    <edge source="Henry" target="Levant">
      <data key="d7">1.0</data>
      <data key="d8">Henry planned to go on a crusade to the Levant but was prevented by rebellions in Gascony.</data>
      <data key="d9">crusade plan,rebellion prevention</data>
      <data key="d10">chunk-92c487c3700be67fb742facf9f0da992</data>
