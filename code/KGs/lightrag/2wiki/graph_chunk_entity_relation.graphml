    <node id="Anglo-Hollandia">
      <data key="d0">Anglo-Hollandia</data>
      <data key="d1">organization</data>
      <data key="d2">Anglo-Hollandia was a company managed by Maurits Binger from 1919 to 1923, aiming to enter the British market.</data>
      <data key="d3">chunk-edcf8a50f1502edd9374004d2dde888d</data>
      <data key="d4">unknown_source</data>
