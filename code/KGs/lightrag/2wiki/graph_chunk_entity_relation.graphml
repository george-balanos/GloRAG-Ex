    <node id="Yongle Emperor">
      <data key="d0">Yongle Emperor</data>
      <data key="d1">person</data>
      <data key="d2">The Yongle Emperor, personal name Zhu Di, was the third Emperor of the Ming dynasty, reigning from 1402 to 1424. He was known for his military campaigns, architectural projects, and efforts to establish his legitimacy.</data>
      <data key="d3">chunk-f58fec195d8efa9069d2477d8a930f4c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782057003</data>
