    <node id="Silent Era">
      <data key="d0">Silent Era</data>
      <data key="d1">event</data>
      <data key="d2">The Silent Era refers to the period in film history when movies were produced without synchronized recorded sound.&lt;SEP&gt;The silent era refers to the period in film history when movies were produced without synchronized recorded sound, spanning from the mid-1890s to the late 1920s.</data>
      <data key="d3">chunk-edcf8a50f1502edd9374004d2dde888d&lt;SEP&gt;chunk-5bec0e24884c0a0461e84d64ffcd5daf</data>
