    <edge source="Henry" target="Edmund Crouchback">
      <data key="d7">1.0</data>
      <data key="d8">Henry attempted to place his son Edmund Crouchback on the throne of Sicily but failed.</data>
      <data key="d9">family ambition,political failure</data>
