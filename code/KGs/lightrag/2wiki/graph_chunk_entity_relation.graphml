    </edge>
    <edge source="John Beach" target="General Joseph Street">
      <data key="d7">1.0</data>
      <data key="d8">John Beach was the son-in-law of General Joseph Street and succeeded him as the Indian Agent to the Sac and Fox tribes.</data>
      <data key="d9">Son-in-law,Succession</data>
      <data key="d10">chunk-d1bb5cd9ff264b572149867bd71c495b</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1782054657</data>
      <data key="d13" />
    </edge>
    <edge source="John Beach" target="Treaty for the Purchase of Iowa">
      <data key="d7">1.0</data>
      <data key="d8">John Beach hosted the council that resulted in the signing of the treaty for the purchase of Iowa from the Sac and Fox Indians.</data>
      <data key="d9">Council Host,Treaty Signing</data>
