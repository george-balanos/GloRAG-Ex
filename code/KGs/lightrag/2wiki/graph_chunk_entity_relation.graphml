    <node id="Toen 't Licht Verdween">
      <data key="d0">Toen 't Licht Verdween</data>
      <data key="d1">content</data>
      <data key="d2">Toen 't Licht Verdween is a 1918 Dutch silent drama film directed by Maurits Binger.</data>
      <data key="d3">chunk-edcf8a50f1502edd9374004d2dde888d</data>
