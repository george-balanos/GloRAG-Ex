    <node id="Tiberius">
      <data key="d0">Tiberius</data>
      <data key="d1">person</data>
      <data key="d2">Tiberius was the Roman emperor from 14 AD and the adoptive father of Caligula. He succeeded Augustus as emperor of Rome.</data>
