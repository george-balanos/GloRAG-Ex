    <node id="Maurice de Canonge">
      <data key="d0">Maurice de Canonge</data>
      <data key="d1">person</data>
      <data key="d2">Maurice de Canonge was a French actor and film director, also known by the name Maurice Cannon.</data>
      <data key="d3">chunk-edcf8a50f1502edd9374004d2dde888d</data>
      <data key="d4">unknown_source</data>
