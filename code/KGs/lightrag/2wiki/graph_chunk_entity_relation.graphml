    <node id="Otto I">
      <data key="d0">Otto I</data>
      <data key="d1">person</data>
      <data key="d2">Otto I, also known as Otto I, Count of Chiny, was the first Count of Chiny and is believed to have Germanic ancestry. He died in 987.</data>
      <data key="d3">chunk-758a0a6b7851ac012d0c9fd434d94410</data>
