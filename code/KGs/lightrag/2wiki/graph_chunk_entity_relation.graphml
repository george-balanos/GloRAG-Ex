    <node id="John the Fearless">
      <data key="d0">John the Fearless</data>
      <data key="d1">person</data>
      <data key="d2">John the Fearless was the Duke of Burgundy from 1404 until his death on 10 September 1419, known for his political dealings and involvement in the Hundred Years' War.</data>
