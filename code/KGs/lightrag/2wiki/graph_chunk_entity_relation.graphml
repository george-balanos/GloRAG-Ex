    <node id="Louis I">
      <data key="d0">Louis I</data>
      <data key="d1">person</data>
      <data key="d2">Louis I, also known as Louis, Count of Verdun, was the Count of Chiny from 987 to 1025 and Count of Verdun from 1024 to 1025. He was murdered in 1025.</data>
