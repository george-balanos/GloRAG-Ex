    </node>
    <node id="Haarlem">
      <data key="d0">Haarlem</data>
      <data key="d1">location</data>
      <data key="d2">Haarlem is the base of operations for Maurits Binger's studio in North Holland.</data>
      <data key="d3">chunk-edcf8a50f1502edd9374004d2dde888d</data>
      <data key="d4">unknown_source</data>
