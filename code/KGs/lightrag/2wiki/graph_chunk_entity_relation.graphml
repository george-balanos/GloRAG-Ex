      <data key="d0">Jianwen Emperor</data>
      <data key="d1">person</data>
      <data key="d2">The Jianwen Emperor was the nephew of the Yongle Emperor and the emperor whom the Yongle Emperor overthrew in 1402.</data>
      <data key="d3">chunk-f58fec195d8efa9069d2477d8a930f4c</data>
      <data key="d4">unknown_source</data>
