    </node>
    <node id="Philip">
      <data key="d0">Philip</data>
      <data key="d1">person</data>
      <data key="d2">Philip was the son and successor of John the Fearless, who sought an alliance with the English after his father's assassination.</data>
      <data key="d3">chunk-339288817d6c7dccf7a63a29fcd9b0ff</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782061185</data>
