    <node id="Agrippina the Elder">
      <data key="d0">Agrippina the Elder</data>
      <data key="d1">person</data>
      <data key="d2">Agrippina the Elder was Augustus's granddaughter and the mother of Caligula. She became entangled in a feud with Tiberius.</data>
