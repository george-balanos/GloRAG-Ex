    <node id="Maurits Binger">
      <data key="d0">Maurits Binger</data>
      <data key="d1">person</data>
      <data key="d2">Maurits Binger was a Dutch film director, producer, and screenwriter of the silent era, known for directing 39 films between 1913 and 1922.</data>
      <data key="d3">chunk-edcf8a50f1502edd9374004d2dde888d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782054611</data>
