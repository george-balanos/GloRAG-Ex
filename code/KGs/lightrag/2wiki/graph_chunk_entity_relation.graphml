    <node id="Antioch">
      <data key="d0">Antioch</data>
      <data key="d1">location</data>
      <data key="d2">Antioch is where Germanicus died in 19 AD.&lt;SEP&gt;Antioch was the capital city of Seleucid Syria, from which Antiochus X was expelled by Antiochus XI.</data>
      <data key="d3">chunk-8d2b3198b39b98b16e57ae034086b62f&lt;SEP&gt;chunk-8c5f8644c7a8e9cadca7a983592b2e99</data>
