    <node id="Caligula">
      <data key="d0">Caligula</data>
      <data key="d1">person</data>
      <data key="d2">Caligula was Roman emperor from 37 to 41 AD, known for his cruelty, extravagance, and ambitious construction projects. He was the son of Germanicus and Agrippina the Elder.</data>
      <data key="d3">chunk-8d2b3198b39b98b16e57ae034086b62f</data>
      <data key="d4">unknown_source</data>
