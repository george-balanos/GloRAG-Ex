    <node id="Stefan Nemanja">
      <data key="d0">Stefan Nemanja</data>
      <data key="d1">person</data>
      <data key="d2">Stefan Nemanja was the Grand Prince of the Serbian Grand Principality from 1166 to 1196. He founded the Nemanjić dynasty and is remembered for his contributions to Serbian culture and history.</data>
      <data key="d3">chunk-3d29580a447ade174bf374d0c7a2d29e</data>
      <data key="d4">unknown_source</data>
