    </edge>
    <edge source="Henry" target="Provisions of Oxford">
      <data key="d7">1.0</data>
      <data key="d8">The Provisions of Oxford were reforms enacted by the barons to reform the royal government.</data>
      <data key="d9">baronial power,political reform</data>
      <data key="d10">chunk-92c487c3700be67fb742facf9f0da992</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1782055634</data>
      <data key="d13" />
    </edge>
    <edge source="Henry" target="King Louis IX">
      <data key="d7">1.0</data>
      <data key="d8">Henry and King Louis IX enacted a peace in 1259, under which Henry gave up his rights to his other lands in France in return for Louis recognizing him as the rightful ruler of Gascony.</data>
      <data key="d9">diplomatic agreement,territorial recognition</data>
      <data key="d10">chunk-92c487c3700be67fb742facf9f0da992</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1782055634</data>
      <data key="d13" />
    </edge>
    <edge source="Henry" target="Simon de Montfort">
      <data key="d7">1.0</data>
      <data key="d8">Simon de Montfort seized power, leading to the Second Barons' War and the Battle of Lewes.</data>
      <data key="d9">political conflict,war</data>
      <data key="d10">chunk-92c487c3700be67fb742facf9f0da992</data>
