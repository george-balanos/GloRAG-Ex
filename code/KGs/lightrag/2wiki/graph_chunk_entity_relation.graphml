    <node id="Johann I Joseph, Prince Of Liechtenstein">
      <data key="d0">Johann I Joseph, Prince Of Liechtenstein</data>
      <data key="d1">person</data>
      <data key="d2">Johann I Joseph, Prince of Liechtenstein, also known as Johann Baptist Josef Adam Johann Nepomuk Aloys Franz De Paula, was born on 26 June 1760 and died on 20 April 1836. He served as Prince of Liechtenstein between 1805 and 1806 and again from 1814 until 1836, and was the last Liechtenstein prince to rule under the Holy Roman Empire.</data>
      <data key="d3">chunk-c181891c0f7c96314618fd1dffd471fc</data>
      <data key="d4">unknown_source</data>
