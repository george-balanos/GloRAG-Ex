    </edge>
    <edge source="Henry" target="Gascony">
      <data key="d7">1.0</data>
      <data key="d8">Rebellions in Gascony prevented Henry from going on a crusade to the Levant.</data>
      <data key="d9">political conflict,rebellion</data>
      <data key="d10">chunk-92c487c3700be67fb742facf9f0da992</data>
      <data key="d11">unknown_source</data>
