    </node>
    <node id="Godfrey the Bearded">
      <data key="d0">Godfrey the Bearded</data>
      <data key="d1">person</data>
      <data key="d2">Godfrey the Bearded was the nephew of Herman of Ename and the son of Gothelo. He coveted the position of Count of Verdun and was later appointed to it.</data>
      <data key="d3">chunk-758a0a6b7851ac012d0c9fd434d94410</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782055853</data>
