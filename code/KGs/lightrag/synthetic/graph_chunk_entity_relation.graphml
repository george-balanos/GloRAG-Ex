    <node id="Xylotian Sky-Skiff">
      <data key="d0">Xylotian Sky-Skiff</data>
      <data key="d1">artifact</data>
      <data key="d2">The Xylotian Sky-Skiff is a lightweight aerial vehicle primarily made from hardened Aero-Coral and clad in Noctilucent Metal.</data>
      <data key="d3">chunk-2d9f68ea236e65773d7fa8dfce96706b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776366082</data>
      <data key="d6" />
    </node>
    <node id="Aero-Coral">
      <data key="d0">Aero-Coral</data>
      <data key="d1">naturalobject</data>
      <data key="d2">Aero-Coral is a bio-engineered substance used in the construction of Xylotian Sky-Skiffs, grown in Xylos's upper atmosphere.</data>
      <data key="d3">chunk-2d9f68ea236e65773d7fa8dfce96706b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776366082</data>
      <data key="d6" />
    </node>
    <node id="Noctilucent Metal">
      <data key="d0">Noctilucent Metal</data>
      <data key="d1">artifact</data>
      <data key="d2">Noctilucent Metal is a thin sheet material used to clad the Aero-Coral frame of Sky-Skiffs, known for glowing faintly in the dark.</data>
      <data key="d3">chunk-2d9f68ea236e65773d7fa8dfce96706b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776366082</data>
      <data key="d6" />
    </node>
    <node id="Xylotian Ground Vehicles">
      <data key="d0">Xylotian Ground Vehicles</data>
      <data key="d1">artifact</data>
      <data key="d2">Xylotian ground vehicles are constructed using volcanic rock for durability.</data>
