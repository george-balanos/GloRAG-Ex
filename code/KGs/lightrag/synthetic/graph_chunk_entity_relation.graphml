    <node id="Propulsion System">
      <data key="d0">Propulsion System</data>
      <data key="d1">artifact</data>
      <data key="d2">The propulsion system of a Sky-Skiff utilizes focused solar winds for movement.</data>
      <data key="d3">chunk-2d9f68ea236e65773d7fa8dfce96706b</data>
